egin\n   Put("Enter the first value: ");\n   Get(First_Value);\n\n   Put("Enter the second value: ");\n   Get(Second_Value);\n\n   Put("Before swapping: ");\n   Put("First Value = ");\n   Put(First_Value);\n   New_Line;\n   Put("Second Value = ");\n   Put(Second_Value);\n   New_Line;\n\n   -- Call the swap procedure and swap the values\n   XOR_Swap(First_Value, Second_Value);\n\n   -- Display swapped values\n   Put("After swapping: ");\n   Put("First Value = ");\n   Put(First_Value);\n   New_Line;\n   Put("Second Value = ");\n   Put(Second_Value);\n   New_Line;\nend Swap_Bool;These examples show the same XOR swap algorithm as the first example, but with different data types. The XOR XOR_Swap is'
